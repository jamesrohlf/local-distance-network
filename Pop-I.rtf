\outl0\strokewidth0 \strokec2 SH0ES (R22): 73.04 \'b1 1.04\
\ls1\ilvl0\kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 SNe II SCM (dJ22): 75.4 \'b1 3.8\
